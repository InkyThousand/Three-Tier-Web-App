# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# Terraform Variables
TF_VAR_aws_region=us-east-1
TF_VAR_environment=dev
TF_VAR_db_password=YourSecurePassword123!

# Usage:
# 1. Copy this file: cp .env.example .env
# 2. Update values in .env with your actual credentials
# 3. Load variables: source .env (or use direnv)
# 4. Run terraform: terraform apply
